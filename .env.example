# Ratings
MIN_RATING_KP=6.5
MIN_RATING_IMDB=6.0

# Torrent filters
MIN_SEEDERS=5
QUALITY_FILTER=1080p
LANGUAGE_FILTER=dubbing
SPEED_TEST_MB=50
MIN_SPEED_MBPS=5.0

# Lampa
LAMPA_SYNC_URL=
LAMPA_CUB_TOKEN=

# API Keys
KP_API_TOKEN=
TMDB_API_KEY=
YOUTUBE_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Torrent sources
JACKETT_URL=http://localhost:9117
JACKETT_API_KEY=

RUTRACKER_LOGIN=
RUTRACKER_PASSWORD=

# TorrServer
TORRSERVER_URL=http://localhost:8090

# Database
DATABASE_URL=sqlite+aiosqlite:///data/movie_recommender.db

# Recommender
RECOMMEND_TOP_N=10
CONTENT_TYPES=movie,series,cartoon

# LLM reranker (Claude Sonnet 4.6)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_RERANK_ENABLED=true
LLM_RERANK_SHORTLIST_SIZE=30
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=60
LLM_DEBUG_LOG=false

# Lampa watch progress thresholds
FINISHED_THRESHOLD=0.80
DROPPED_MIN_THRESHOLD=0.10
DROPPED_MAX_THRESHOLD=0.50
